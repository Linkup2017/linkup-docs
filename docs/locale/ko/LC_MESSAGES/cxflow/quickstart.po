msgid "Set up structured metadata (requirements, test cases)"
msgstr "구조화된 메타데이터 설정 (요구사항, 테스트 케이스)"

#: ../../cxflow/quickstart.md:101
#, python-brace-format
msgid "{doc}`registry`"
msgstr "{doc}`registry`"

#: ../../cxflow/quickstart.md:101
msgid "Use templates and gate reviews"
msgstr "템플릿 및 게이트 리뷰 사용"

#: ../../cxflow/quickstart.md:101
#, python-brace-format
msgid "{doc}`engine`"
msgstr "{doc}`engine`"

#: ../../cxflow/quickstart.md:101
msgid "Publish documents as PDF / DOCX"
msgstr "PDF / DOCX로 문서 배포"

#: ../../cxflow/quickstart.md:101
#, python-brace-format
msgid "{doc}`portal-publishing`"
msgstr "{doc}`portal-publishing`"

#: ../../cxflow/quickstart.md:101
msgid "Sync documents with Git"
msgstr "Git과 문서 동기화"

#: ../../cxflow/quickstart.md:101
#, python-brace-format
msgid "{doc}`git-sync`"
msgstr "{doc}`git-sync`"

#: ../../cxflow/quickstart.md:101
msgid "Connect AI agents via MCP"
msgstr "MCP를 통한 AI 에이전트 연결"

#: ../../cxflow/quickstart.md:101
#, python-brace-format
msgid "{doc}`mcp-integration`"
msgstr "{doc}`mcp-integration`"

#: ../../cxflow/quickstart.md:118
msgid "Recommended Install Order"
msgstr "권장 설치 순서"

#: ../../cxflow/quickstart.md:131
msgid "Install `lu_cxflow_docs` first, then add modules as your needs grow."
msgstr "`lu_cxflow_docs`를 먼저 설치한 후 필요에 따라 모듈을 추가하세요."
