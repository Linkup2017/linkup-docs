msgstr "영업 및 CRM"

#: ../../ai-agent/domain-routing.md:32
msgid "`sale.order`, `crm.lead`, `res.partner`, `sale.report`"
msgstr "`sale.order`, `crm.lead`, `res.partner`, `sale.report`"

#: ../../ai-agent/domain-routing.md:32
msgid "`finance`"
msgstr "`finance`"

#: ../../ai-agent/domain-routing.md:32
