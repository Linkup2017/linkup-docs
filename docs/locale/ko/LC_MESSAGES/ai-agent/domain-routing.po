msgstr "재무 및 회계"

#: ../../ai-agent/domain-routing.md:32
msgid ""
"`account.move`, `account.payment`, `account.journal`, "
"`account.analytic.line`"
msgstr ""
"`account.move`, `account.payment`, `account.journal`, "
"`account.analytic.line`"

#: ../../ai-agent/domain-routing.md:32
msgid "`inventory`"
msgstr "`inventory`"

#: ../../ai-agent/domain-routing.md:32
msgid "Inventory & Procurement"
msgstr "재고 및 구매"

#: ../../ai-agent/domain-routing.md:32
msgid "`stock.picking`, `stock.quant`, `purchase.order`, `product.product`"
msgstr "`stock.picking`, `stock.quant`, `purchase.order`, `product.product`"

#: ../../ai-agent/domain-routing.md:32
msgid "`hr`"
msgstr "`hr`"

#: ../../ai-agent/domain-routing.md:32
