msgstr "코딩 및 구조화된 출력"

#: ../../ai-agent/configuration.md:95
msgid "`llama3.1:8b`"
msgstr "`llama3.1:8b`"

#: ../../ai-agent/configuration.md:95
msgid "Strong at JSON/function output"
msgstr "JSON/함수 출력에 강점"

#: ../../ai-agent/configuration.md:95
msgid "Korean language tasks"
msgstr "한국어 작업"

#: ../../ai-agent/configuration.md:95
msgid "Good Korean support out of the box"
msgstr "기본적으로 우수한 한국어 지원"

#: ../../ai-agent/configuration.md:95
msgid "Low-resource environments"
msgstr "저사양 환경"

#: ../../ai-agent/configuration.md:95
