msgid "3 consecutive check errors\n(circuit breaker)"
msgstr "3 consecutive check errors\n(circuit breaker)"

#: ../../ai-agent/proactive-alerts.md:136
msgid "Manual reset"
msgstr "Manual reset"

#: ../../ai-agent/proactive-alerts.md:136
msgid "auto_restart_after_hours elapsed"
